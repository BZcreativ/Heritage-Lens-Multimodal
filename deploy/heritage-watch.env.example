# Heritage Lens abuse watcher config. Restart heritage-watch.service after edits.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=heritagelens-alerts-CHANGEME
# Thresholds (uncomment to override defaults):
# HW_API_FLOOD=60     # /api/* requests per IP per 60s
# HW_ERR_SCAN=40      # 4xx responses per IP per 60s
# HW_SENSITIVE=5      # POST upload/ingest per IP per 600s
# HW_COOLDOWN=900     # seconds to suppress repeat alerts per IP+rule

# Copy this to config/.env and fill in your API keys.
# The real config/.env is gitignored — NEVER commit it.

# OpenRouter API (RECOMMENDED - provides access to multiple models)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# KIMI API (optional - for Moonshot AI models)
KIMI_API_KEY=

# GLM-4V Vision API (optional - for enhanced image analysis)
# Get your key at: https://z.ai/manage-apikey/apikey-list
# Enables AI-powered image captioning and cultural context analysis
GLM_API_KEY=

# OpenAI API — routed through OpenRouter (LLM calls only; embeddings use HuggingFace locally)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Anthropic API (optional - for Claude models)
ANTHROPIC_API_KEY=

# Google AI API (optional - for Gemini models)
GOOGLE_API_KEY=

# Qdrant URL
QDRANT_URL=http://localhost:6333

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# Image Processing Settings
IMAGE_CACHE_DIR=./data/cache
MAX_IMAGE_SIZE=224
CLIP_MODEL=clip-ViT-B-32

# Optional: Hugging Face Token
HF_TOKEN=
